{
  "name": "@ykstormsorg/goldset",
  "version": "0.2.4",
  "description": "Lock your AI app's behavior. Golden datasets + LLM-as-judge + structural assertions in CI.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "goldset": "./dist/cli.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.check.json",
    "lint": "eslint src action tests",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": [
    "ai",
    "llm",
    "evaluation",
    "testing",
    "golden-dataset",
    "llm-as-judge",
    "structural-assertions",
    "ci",
    "github-action"
  ],
  "homepage": "https://github.com/ykstorm/goldset",
  "repository": "github:ykstorm/goldset",
  "author": "Lakshyaraj <raolakshyaraj@gmail.com>",
  "license": "Apache-2.0",
  "devDependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^9.39.4",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.1",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
